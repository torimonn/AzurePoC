subscription_id = null

env         = "dev"
location    = "japaneast"
name_prefix = "ocr-demo"

resource_group_name = "rg-ocr-demo-dev"

tags = {
  app     = "ocr-demo"
  env     = "dev"
  owner   = "toshiki"
  purpose = "hands-on"
}

vnet_name          = "vnet-ocr-demo-dev"
vnet_address_space = ["10.30.0.0/24"]
dns_servers        = []

snet_aca_infra_name            = "snet-aca-infra"
snet_aca_infra_prefixes        = ["10.30.0.0/25"]
snet_private_endpoint_name     = "snet-private-endpoint"
snet_private_endpoint_prefixes = ["10.30.0.128/26"]
snet_admin_name                = "snet-admin"
snet_admin_prefixes            = ["10.30.0.192/28"]

# 初期基盤ではHub未接続の可能性があるためUDRを無効にします。
hub_firewall_private_ip    = null
enable_udr_to_hub_firewall = false

log_analytics_workspace_name = "law-ocr-demo-dev"
log_analytics_retention_days  = 30

ai_name         = "ai-ocr-demo-dev"
ai_location     = "japaneast"
ai_sku_name     = "S0"
ai_project_name = "proj-default"

create_storage_account           = true
storage_account_name             = "stocrocrdemodev001"
storage_account_tier             = "Standard"
storage_account_replication_type = "LRS"
storage_account_access_tier      = "Hot"

# AI Services、アプリ用Storage、Key Vaultはコード側でPublic Network Accessを
# 常に無効化し、Network Ruleの既定アクションをDenyに固定しています。
storage_network_bypass = ["AzureServices"]

# 管理VMからbackendへ到達できることを確認するまではfalseにします。
# trueへ変更するときはbootstrap outputのResource IDとStorage Account名を設定します。
enable_state_storage_private_endpoint = false
state_storage_account_id              = null
state_storage_account_name            = null

create_key_vault     = true
key_vault_name       = "kv-ocr-demo-dev-001"
key_vault_sku_name   = "standard"

key_vault_network_bypass             = "AzureServices"
key_vault_soft_delete_retention_days = 7
key_vault_purge_protection_enabled   = false

create_admin_vm                = true
# Hub接続と必要な外向き通信を確認するまではfalseにします。
enable_admin_vm_entra_id_login = false
admin_vm_name                  = "vm-ocr-demo-dev-admin"
admin_vm_size                  = "Standard_B1s"
admin_username                 = "azureuser"
admin_private_ip_address       = "10.30.0.196"

# 内部break-glass用のSSH公開鍵です。秘密鍵は保存しないでください。
admin_ssh_public_key = "<internal-break-glass-ssh-public-key>"

# Entra IDログインRoleをTerraformで付与する場合、ユーザーまたはグループのObject IDを設定します。
# Entra ID SSHがfalseの場合は両方nullにします。trueかつnullの場合、拡張だけを導入し、
# Role Assignmentは共通基盤側などで別途実施します。
admin_vm_login_principal_id   = null
admin_vm_login_principal_type = null

# nullの場合、管理VM用NSGは作成しますがSSH許可ルールは作成しません。
hub_azure_bastion_subnet_prefix = null
